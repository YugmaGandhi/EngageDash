# =========================================================================
# EngageDash backend configuration — the single source of truth for the backend.
# Copy to `backend/.env` and fill in values.
#
# These values target LOCAL development (hosts = localhost). When running via
# docker-compose, compose overrides POSTGRES_HOST/REDIS_HOST with the service
# names (postgres/redis) — nothing else changes.
# =========================================================================

# ---------- App ----------
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- Database ----------
POSTGRES_USER=engagedash
POSTGRES_PASSWORD=change-me
POSTGRES_DB=engagedash
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- JWT / Auth ----------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- AI (DeepSeek via NVIDIA, OpenAI-compatible) ----------
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=
AI_MODEL=deepseek-ai/deepseek-v4-flash

# ---------- Cache ----------
DASHBOARD_CACHE_TTL_SECONDS=120
