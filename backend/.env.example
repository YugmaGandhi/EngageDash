# =========================================================================
# EngageDash backend — environment template (for running outside compose)
# Copy to `.env` for local non-Docker runs. In Docker, values come from the
# root .env via docker-compose.
# =========================================================================

# ---------- App ----------
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- Database ----------
# Local (non-Docker) example uses localhost; compose overrides host to `postgres`.
DATABASE_URL=postgresql+psycopg://engagedash:change-me@localhost:5432/engagedash

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT / Auth ----------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- AI (DeepSeek via NVIDIA, OpenAI-compatible) ----------
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=
AI_MODEL=deepseek-ai/deepseek-v4-flash

# ---------- Cache ----------
DASHBOARD_CACHE_TTL_SECONDS=120
