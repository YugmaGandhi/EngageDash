# =========================================================================
# EngageDash — root environment template
# Copy to `.env` and fill in values. Used by docker-compose to wire services.
# =========================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=engagedash
POSTGRES_PASSWORD=change-me
POSTGRES_DB=engagedash
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Backend ----------
# Assembled from the Postgres/Redis vars above when running in compose.
DATABASE_URL=postgresql+psycopg://engagedash:change-me@postgres:5432/engagedash
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- JWT / Auth ----------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- AI (DeepSeek via NVIDIA, OpenAI-compatible) ----------
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=
AI_MODEL=deepseek-ai/deepseek-v4-flash

# ---------- Cache ----------
DASHBOARD_CACHE_TTL_SECONDS=120

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
